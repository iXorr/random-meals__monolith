{{#if meal}}

<div class="max-w-5xl mx-auto">
    <h1 class="text-2xl md:text-3xl font-bold mb-6">
        Блюдо №{{ meal.id }} - {{ meal.title }}
    </h1>

    <div class="flex flex-col md:flex-row gap-6">
        <img src="{{ meal.img }}" alt="food"
             class="w-[300px] md:w-[450px] h-[200px] md:h-[350px]
                    rounded-[15px] border border-black object-cover">

        <p class="text-base md:text-lg text-justify">
            {{ meal.recipe }}
        </p>
    </div>
</div>

{{/if}}
